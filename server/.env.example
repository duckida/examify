# AI Provider Configuration
# ========================
# The "Free endpoint" option in the app uses this server-side key.
# The "Hack Club AI" option uses a user-provided API key from the client.

# Required for the "Free endpoint" option:
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key

# Optional: override the default model used by the "Free endpoint"
# LLM_MODEL=gemini-3.1-flash-lite
